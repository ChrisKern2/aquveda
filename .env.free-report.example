# ============================================================
# Free water report — environment variables
# Copy these into Vercel (Project > Settings > Environment Variables)
# and into a local .env for `vercel dev`. Never commit real keys.
# ============================================================

# Your live site origin (used to build the report PDF link in the email)
SITE_URL=https://wellbrookwater.com

# Where "Request a free quote" points (your Jobber quote page)
QUOTE_URL=https://wellbrookwater.com/contact

# --- Resend (email) ---
# Get a key at https://resend.com after verifying wellbrookwater.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Must be on a domain you verified in Resend
REPORT_FROM_EMAIL=Wellbrook Water <reports@wellbrookwater.com>
REPLY_TO_EMAIL=chris@wellbrookwater.com

# --- Jobber (auto-create lead) ---
# Create an app at https://developer.getjobber.com, then OAuth once to get a refresh token.
JOBBER_CLIENT_ID=xxxxxxxxxxxxxxxx
JOBBER_CLIENT_SECRET=xxxxxxxxxxxxxxxx
JOBBER_REFRESH_TOKEN=xxxxxxxxxxxxxxxx
# Optional: pin the GraphQL API version your app supports
JOBBER_API_VERSION=2025-01-20
