---
import { business } from "../data/site";
import Icon from "./Icon.astro";

interface Props {
  title?: string;
  subtitle?: string;
  // Renamed from the legacy "red"/"parchment" (a pre-Ridgeline brand) so the
  // prop describes what actually renders.
  tone?: "navy" | "limestone";
}
const {
  title = "See What's In Your Water",
  subtitle = "Get a free, plain-English report on your area's water. We'll review it, then call to put together a no-obligation quote.",
  tone = "navy",
} = Astro.props;

const isNavy = tone === "navy";
const bg = isNavy
  ? "linear-gradient(120% 130% at 80% 20%, #2278b5 0%, #143c5f 55%, #143c5f 100%)"
  : "#f0eae0";
const titleColor = isNavy ? "#fff" : "#143c5f";
const subColor = isNavy ? "rgba(255,255,255,.85)" : "#51606c";
---
<section style={`background:${bg}`}>
  <div class="wrap" style="padding-top:56px;padding-bottom:56px;display:flex;align-items:center;justify-content:space-between;gap:30px;flex-wrap:wrap">
    <div style="max-width:560px">
      <h2 style={`font:700 36px/1.08 var(--font-display);letter-spacing:.01em;color:${titleColor};margin-bottom:10px;text-wrap:balance`}>{title}</h2>
      <p style={`font:400 17px/1.6 var(--font-body);color:${subColor}`}>{subtitle}</p>
    </div>
    <div class="stack-sm" style="display:flex;align-items:center;gap:14px;flex-wrap:wrap">
      <a class="btn btn-cta" href="/free-report" style="font:700 16px/1 var(--font-body);padding:17px 30px">Get Your Free Water Report <Icon name="arrow" size={17} /></a>
      <a class={isNavy ? "btn btn-ghost" : "btn btn-navy"} href={business.phoneHref} style="font:700 16px/1 var(--font-body);padding:17px 26px">
        <Icon name="phone" size={17} /> {business.phoneDisplay}
      </a>
    </div>
  </div>
</section>
