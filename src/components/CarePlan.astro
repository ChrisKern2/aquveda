---
import { carePlan } from "../data/site";
import Icon from "./Icon.astro";
---
<section id="care-plan" style="background:#fff">
  <div class="wrap" style="padding-top:74px;padding-bottom:74px">
    <div style="text-align:center;max-width:660px;margin:0 auto 46px">
      <div style="font:600 12.5px/1 var(--font-body);letter-spacing:.14em;text-transform:uppercase;color:#15919b;margin-bottom:12px">{carePlan.eyebrow}</div>
      <h2 style="font:700 40px/1.05 var(--font-display);letter-spacing:.01em;color:#0e3a43;margin-bottom:14px;text-wrap:balance">{carePlan.title}</h2>
      <p style="font:400 17px/1.6 var(--font-body);color:#5e7177">{carePlan.intro}</p>
    </div>

    <div class="grid-3" style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;align-items:stretch">
      {carePlan.tiers.map((t) => (
        <div class="card" style={`display:flex;flex-direction:column;padding:32px 26px 28px;position:relative;background:#fff;${t.popular ? "border:2px solid #15919b;box-shadow:0 22px 55px rgba(14,58,67,.16)" : "border:1px solid #e6eef0"}`}>
          {t.popular && (
            <span style="position:absolute;top:-13px;left:50%;transform:translateX(-50%);background:#15919b;color:#fff;font:700 11px/1 var(--font-body);letter-spacing:.08em;text-transform:uppercase;padding:7px 15px;border-radius:100px;white-space:nowrap">Most Popular</span>
          )}
          <h3 style="font:700 21px/1.15 var(--font-display);letter-spacing:.01em;color:#0e3a43;margin-bottom:10px">{t.name}</h3>
          <div style="display:flex;align-items:baseline;gap:8px">
            <span style="font:700 34px/1 var(--font-display);color:#0e3a43">{t.monthly}</span>
            <span style="font:600 14px/1 var(--font-body);color:#15919b">/month</span>
          </div>
          <div style="font:500 13px/1.4 var(--font-body);color:#5e7177;margin-top:5px">or {t.annual}</div>

          <ul style="list-style:none;padding:0;margin:18px 0 0;display:flex;flex-direction:column;gap:10px">
            {t.features.map((f) => (
              f.endsWith(":") ? (
                <li style="font:700 13px/1.4 var(--font-body);color:#5e7177;margin-top:2px">{f}</li>
              ) : (
                <li style="display:flex;align-items:flex-start;gap:10px">
                  <span style="color:#1f8a5b;margin-top:1px;flex:none"><Icon name="check" size={17} /></span>
                  <span style="font:500 14px/1.45 var(--font-body);color:#0e3a43">{f}</span>
                </li>
              )
            ))}
          </ul>
        </div>
      ))}
    </div>

    <p style="text-align:center;font:500 14px/1.6 var(--font-body);color:#5e7177;margin-top:26px;max-width:640px;margin-left:auto;margin-right:auto">
      Add Wellbrook Care at your install and your first care visit is scheduled before we leave.
      Prepay the year and get one month free.
    </p>
  </div>
</section>
