---
import Icon from "./Icon.astro";
const items = [
  { icon: "wrench", title: "Licensed & insured installers", body: "Every system fitted by a licensed, insured installer." },
  { icon: "badge", title: "Lifetime workmanship warranty", body: "We stand behind every install for as long as you own your home." },
  { icon: "drop", title: "Sized to your home", body: "Equipment matched to your water, not a box off a shelf." },
  { icon: "tag", title: "Free, no-obligation quote", body: "Get a clear, upfront quote before you spend a dollar." },
];
---
<section style="background:#fff;border-bottom:1px solid rgba(20, 60, 95,.08)">
  <div class="wrap" style="padding-top:34px;padding-bottom:34px;display:grid;grid-template-columns:repeat(4,1fr);gap:22px">
    {items.map((i) => (
      <div style="display:flex;align-items:flex-start;gap:13px">
        <span style="width:44px;height:44px;border-radius:11px;background:#f0eae0;display:flex;align-items:center;justify-content:center;color:#1a5e91;flex:none"><Icon name={i.icon} size={22} /></span>
        <span style="display:flex;flex-direction:column;gap:3px">
          <span style="font:700 14.5px/1.2 var(--font-body);color:#143c5f">{i.title}</span>
          <span style="font:400 12.5px/1.45 var(--font-body);color:#51606c">{i.body}</span>
        </span>
      </div>
    ))}
  </div>
  <style>
    @media (max-width:880px){ section > div[style*="repeat(4"]{grid-template-columns:1fr 1fr !important} }
    @media (max-width:520px){ section > div[style*="repeat(4"]{grid-template-columns:1fr !important} }
  </style>
</section>
