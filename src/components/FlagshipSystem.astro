---
import { flagship, business } from "../data/site";
import Icon from "./Icon.astro";
---
<section id="flagship" style="background:#e9e1d2">
  <div class="wrap" style="padding-top:74px;padding-bottom:74px">
    <div class="card hero-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:0;overflow:hidden;box-shadow:0 24px 60px rgba(14,58,67,.16);border:none">
      <!-- Image -->
      <div style="background:linear-gradient(160deg,#0e3a43,#0b2a31);display:flex;align-items:center;justify-content:center;padding:36px">
        <img src={flagship.image} alt={flagship.imageAlt} width="900" height="520" loading="lazy" style="width:100%;height:auto;border-radius:14px"/>
      </div>
      <!-- Content -->
      <div style="padding:44px 44px 40px;display:flex;flex-direction:column;gap:16px;background:#fff">
        <div style="font:600 12.5px/1 var(--font-body);letter-spacing:.14em;text-transform:uppercase;color:#15919b">{flagship.eyebrow}</div>
        <h2 style="font:700 34px/1.08 var(--font-display);letter-spacing:.01em;color:#0e3a43;text-wrap:balance">{flagship.name}</h2>
        <p style="font:400 16.5px/1.6 var(--font-body);color:#42505f">{flagship.tagline}</p>
        <div style="display:flex;align-items:baseline;gap:12px;flex-wrap:wrap;margin-top:2px">
          <span style="font:700 30px/1 var(--font-display);color:#0e3a43">{flagship.price}</span>
          <span style="font:500 14px/1.4 var(--font-body);color:#5e7177">{flagship.priceNote}</span>
        </div>
        <ul style="list-style:none;padding:0;margin:6px 0 0;display:flex;flex-direction:column;gap:10px">
          {flagship.features.map((f) => (
            <li style="display:flex;align-items:flex-start;gap:10px"><span style="color:#1f8a5b;margin-top:1px;flex:none"><Icon name="check" size={18} /></span><span style="font:500 14.5px/1.5 var(--font-body);color:#0e3a43">{f}</span></li>
          ))}
        </ul>
        <div class="stack-sm" style="display:flex;align-items:center;gap:14px;flex-wrap:wrap;margin-top:10px">
          <a class="btn btn-primary" href="/contact" style="font:700 15px/1 var(--font-body);padding:16px 26px">Get a Free Water Test <Icon name="arrow" size={17} /></a>
          <a class="btn btn-navy" href={business.phoneHref} style="font:700 15px/1 var(--font-body);padding:16px 24px"><Icon name="phone" size={16} /> {business.phoneDisplay}</a>
        </div>
      </div>
    </div>
  </div>
</section>
