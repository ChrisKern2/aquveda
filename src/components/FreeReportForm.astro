---
// Free water report form.
//
// The form itself is a HighLevel (LeadConnector) embed and posts DIRECTLY to
// the CRM. There is deliberately no local submit handler here: no POST to
// /api/free-report, no Zapier webhook, and no Meta Lead event — HighLevel owns
// the submission end to end.
//
// Because of that, anything the old handler did now has to be done by the
// HighLevel form/workflow instead:
//   - emailing the customer their area's report PDF
//   - the in-area vs out-of-area ZIP split
//   - notifying the team
//   - firing the Meta "Lead" conversion
//
// The surrounding card, heading and subtext are unchanged.
---
<div class="wb-report card" style="padding:30px;max-width:560px;margin:0 auto;box-shadow:0 20px 50px rgba(20,30,50,.12);border:none;border-radius:16px;background:#fff">
  <h2 style="margin:0 0 6px;color:#143c5f;font-size:26px;font-weight:800">Free water report for your zip</h2>
  <p style="margin:0 0 22px;color:#51606c;font-size:15px;line-height:22px">
    See what public testing shows for your area: hardness, chlorine, disinfection byproducts, and PFAS. No cost, no salesperson.
  </p>

  <!-- HighLevel form embed. Height is set to the form's own data-height (854)
       rather than the snippet's height:100% — the card has no fixed height, so
       100% would collapse the iframe to 0 and the form would be invisible.
       form_embed.js still resizes it to fit the live content. -->
  <iframe
    src="https://api.leadconnectorhq.com/widget/form/RMaiQcWNgPCGwWVfnEiY"
    style="width:100%;height:854px;border:none;border-radius:8px;display:block"
    id="inline-RMaiQcWNgPCGwWVfnEiY"
    data-layout="{'id':'INLINE'}"
    data-trigger-type="alwaysShow"
    data-trigger-value=""
    data-activation-type="alwaysActivated"
    data-activation-value=""
    data-deactivation-type="neverDeactivate"
    data-deactivation-value=""
    data-form-name="Free Water Report Form"
    data-height="854"
    data-layout-iframe-id="inline-RMaiQcWNgPCGwWVfnEiY"
    data-form-id="RMaiQcWNgPCGwWVfnEiY"
    title="Free Water Report Form"
  ></iframe>
  <!-- is:inline keeps Astro from bundling/deferring the loader, which would
       stop it from finding and resizing the iframe above. -->
  <script is:inline src="https://link.msgsndr.com/js/form_embed.js"></script>
</div>
