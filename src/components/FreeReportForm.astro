---
// Free water report form. Posts to /api/free-report.
// Drop <FreeReportForm /> onto any page. Self-contained styling.
---
<div class="wb-report card" style="padding:30px;max-width:560px;margin:0 auto;box-shadow:0 20px 50px rgba(20,30,50,.12);border:none;border-radius:16px;background:#fff">
  <h2 style="margin:0 0 6px;color:#0E3A43;font-size:26px;font-weight:800">Free water report for your zip</h2>
  <p style="margin:0 0 22px;color:#5d6b71;font-size:15px;line-height:22px">
    See what public testing shows for your area: hardness, chlorine, disinfection byproducts, and PFAS. No cost, no salesperson.
  </p>

  <form id="wb-report-form">
    <!-- honeypot: hidden from humans -->
    <input type="text" name="website" tabindex="-1" autocomplete="off"
      style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0" aria-hidden="true" />

    <!-- captures the system tier a visitor clicked (from ?system=), sent with the lead -->
    <input type="hidden" name="system" id="wb-system" />
    <div id="wb-interest" style="display:none;margin:0 0 16px;padding:12px 14px;background:#eaf4f4;border-radius:10px;color:#0E3A43;font-size:14px;line-height:1.4"></div>

    <div style="display:grid;gap:14px">
      <input name="firstName" required placeholder="First name *" autocomplete="given-name" class="wb-in" />
      <input name="email" type="email" required placeholder="Email *" autocomplete="email" class="wb-in" />
      <input name="phone" type="tel" required placeholder="Phone *" autocomplete="tel" class="wb-in" />
      <input name="zip" required inputmode="numeric" maxlength="5" placeholder="Zip code *" autocomplete="postal-code" class="wb-in" />

      <select name="waterSource" required class="wb-in" aria-label="Main water source">
        <option value="">Is your main water source... *</option>
        <option>City water</option>
        <option>Well water</option>
        <option>Not sure</option>
      </select>

      <select name="ownsHome" required class="wb-in" aria-label="Do you own your home?">
        <option value="">Do you own your home? *</option>
        <option value="yes">Yes, I own it</option>
        <option value="no">No, I rent</option>
      </select>

      <select name="concern" class="wb-in" aria-label="Main water concern">
        <option value="">Main water concern (optional)</option>
        <option>Hard water, spots, or scale</option>
        <option>Drinking water taste or odor</option>
        <option>Contamination or PFAS</option>
        <option>On a private well</option>
        <option>Not sure, just want the report</option>
      </select>

      <button type="submit" id="wb-submit"
        style="background:#15919B;color:#fff;border:none;font-weight:800;font-size:16px;padding:15px;border-radius:30px;cursor:pointer">
        Get my free report
      </button>
    </div>

    <p style="margin:14px 0 0;color:#8a9aa0;font-size:12px;line-height:17px">
      We use your details to send your report and follow up about water treatment. We never sell your information.
    </p>
  </form>

  <div id="wb-result" style="display:none"></div>
</div>

<style>
  .wb-in{width:100%;box-sizing:border-box;padding:14px 16px;border:1px solid #d6dfe2;border-radius:10px;font-size:15px;color:#1e2d34;background:#fff}
  .wb-in:focus{outline:none;border-color:#15919B;box-shadow:0 0 0 3px rgba(21,145,155,.15)}
</style>

<script>
  const form = document.getElementById("wb-report-form");
  const result = document.getElementById("wb-result");
  const btn = document.getElementById("wb-submit");

  // If they arrived from a "Get Started" tier button, capture which system
  // they're interested in and show it, so it rides along with the lead.
  const system = new URLSearchParams(location.search).get("system");
  if (system) {
    document.getElementById("wb-system").value = system;
    const banner = document.getElementById("wb-interest");
    banner.textContent = "You're interested in: " + system + ". We'll size it for your home and go over it on the call.";
    banner.style.display = "block";
  }

  function show(html) {
    form.style.display = "none";
    result.style.display = "block";
    result.innerHTML = html;
  }

  // ---- Zapier webhook: the lead destination ----
  const ZAPIER_WEBHOOK = "https://hooks.zapier.com/hooks/catch/28133353/4uop5l5/";

  // POST the lead with retry + backoff. mode:"cors" lets us read response.ok
  // (urlencoded is a CORS "simple request", so no preflight); Zapier intermittently
  // returns 503, so we retry. Runs in the background; never blocks the success UI.
  async function sendLead(body) {
    for (let i = 0; i < 3; i++) {
      try {
        const r = await fetch(ZAPIER_WEBHOOK, {
          method: "POST",
          mode: "cors",
          headers: { "Content-Type": "application/x-www-form-urlencoded" },
          body,
        });
        if (r.ok) return true; // Zapier returned 200 -> lead delivered
      } catch (e) {}
      await new Promise((res) => setTimeout(res, 1500 * (i + 1))); // 1.5s, 3s, 4.5s
    }
    // All retries failed. The server-side handler already emailed the team, so the
    // lead is not lost; log for visibility and never block the success UI.
    console.error("Zapier webhook failed after 3 attempts; lead still captured via the team email.");
    return false;
  }

  function sendToZapier() {
    // Guard: the caller only invokes this for validated, non-honeypot
    // submissions the server already accepted; this is just belt-and-suspenders.
    if (form.website && form.website.value.trim()) return;

    const fd = new FormData(form);
    const rawName = (fd.get("firstName") || "").toString().trim();
    const sp = rawName.indexOf(" "); // single name field -> split on first space
    const ownMap = { yes: "Yes, I own it", no: "No, I rent" };
    const payload = {
      first_name: sp === -1 ? rawName : rawName.slice(0, sp),
      last_name: sp === -1 ? "" : rawName.slice(sp + 1).trim(),
      email: (fd.get("email") || "").toString().trim(),
      phone: (fd.get("phone") || "").toString().trim(),
      zip: (fd.get("zip") || "").toString().trim(),
      water_source: (fd.get("waterSource") || "").toString(),
      own_home: ownMap[(fd.get("ownsHome") || "").toString()] || "",
      concern: (fd.get("concern") || "").toString(),
    };

    // Deliver in the background with retries; do not await (never blocks success).
    sendLead(new URLSearchParams(payload).toString());
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.textContent = "Sending...";

    const data = Object.fromEntries(new FormData(form).entries());

    try {
      const res = await fetch("/api/free-report", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });
      const json = await res.json();

      if (!res.ok) {
        btn.disabled = false;
        btn.textContent = "Get my free report";
        alert(json.error || "Something went wrong. Please try again.");
        return;
      }

      // Validated, non-bot submission accepted -> send the lead to Zapier,
      // fire-and-forget, immediately before showing the success state.
      if (json.status !== "ignored") sendToZapier();

      if (json.status === "out_of_area") {
        show(`<h2 style="color:#0E3A43;font-size:22px;margin:0 0 10px">We are not in your area yet</h2>
          <p style="color:#5d6b71;font-size:15px;line-height:23px;margin:0">
          Thanks. Right now Wellbrook serves Montgomery and Chester County and the nearby western suburbs,
          and your zip is outside that area. We just emailed you, and we will reach out if we expand to you.</p>`);
      } else {
        show(`<h2 style="color:#0E3A43;font-size:22px;margin:0 0 10px">Check your email</h2>
          <p style="color:#5d6b71;font-size:15px;line-height:23px;margin:0">
          Your water report is on the way, it should land in a minute or two. We'll also give you a call shortly at the number you provided to go over your results and put together a free quote, no pressure.</p>`);
      }
    } catch (err) {
      btn.disabled = false;
      btn.textContent = "Get my free report";
      alert("Network error. Please try again.");
    }
  });
</script>
