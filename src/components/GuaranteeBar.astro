---
import { guarantee } from "../data/site";
import Icon from "./Icon.astro";
---
<section style="background:#0e3a43">
  <div class="wrap" style="padding-top:44px;padding-bottom:44px;display:flex;align-items:center;gap:26px;flex-wrap:wrap">
    <div style="width:66px;height:66px;border-radius:16px;background:rgba(61,184,198,.16);display:flex;align-items:center;justify-content:center;color:#7fd3dc;flex:none">
      <Icon name="shield" size={34} />
    </div>
    <div style="flex:1;min-width:280px">
      <div style="font:600 12px/1 var(--font-body);letter-spacing:.14em;text-transform:uppercase;color:#7fd3dc;margin-bottom:9px">{guarantee.title}</div>
      <p style="font:700 22px/1.3 var(--font-display);color:#fff;letter-spacing:.01em;margin:0 0 8px;text-wrap:balance">{guarantee.promise}</p>
      <p style="font:400 14.5px/1.6 var(--font-body);color:#cde6e8;margin:0;max-width:720px">{guarantee.detail}</p>
    </div>
  </div>
</section>
