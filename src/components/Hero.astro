---
import { business, ENABLE_REVIEWS } from "../data/site";
import Icon from "./Icon.astro";
---
<section style="position:relative;overflow:hidden;background:#143c5f">
  <!-- Water illustration background (swap /images/hero-home.svg with a real photo) -->
  <img
    src="/images/hero-home.svg"
    alt="Clean, filtered water ripples and a droplet, representing whole-home water treatment across the greater Philadelphia area"
    width="1600" height="900" fetchpriority="high"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:.5"
  />
  <div style="position:absolute;inset:0;background:radial-gradient(120% 130% at 78% 12%, rgba(20, 60, 95,.62) 0%, rgba(17, 45, 72,.82) 46%, rgba(22, 35, 44,.93) 100%)"></div>
  <div style="position:absolute;top:0;left:0;width:100%;height:4px;background:linear-gradient(90deg,#1a5e91 0%,#1a5e91 60%,transparent 100%)"></div>

  <div class="wrap" style="position:relative;padding-top:96px;padding-bottom:104px;max-width:900px">
    <div style="display:inline-flex;align-items:center;gap:9px;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.16);padding:8px 15px;border-radius:100px;margin-bottom:22px;color:#7dbee6">
      <Icon name="star" size={15} />
      <span style="font:600 12.5px/1 var(--font-body);color:#7dbee6;letter-spacing:.04em">WHOLE-HOME FILTRATION, SOFTENING &amp; DRINKING WATER</span>
    </div>

    <h1 class="hero-h1" style="font:700 56px/1.05 var(--font-display);letter-spacing:.01em;color:#fff;text-wrap:balance;margin-bottom:20px">
      Cleaner, softer, better-tasting water across <span style="color:#7dbee6">Greater Philadelphia</span>
    </h1>

    <p style="font:400 19px/1.65 var(--font-body);color:#d7e7f3;max-width:560px;margin-bottom:14px">
      Whole-home filtration, reverse osmosis, well water treatment, and specialty systems across Greater Philadelphia, with a focus on the western suburbs. Licensed, fully insured, and backed by our lifetime workmanship warranty.
    </p>
    <p style="font:600 16px/1.5 var(--font-body);color:#fff;max-width:560px;margin-bottom:28px">Our Complete Home Water System covers it all, <span style="color:#7dbee6">$2,699 installed</span> during founder pricing.</p>

    <div class="stack-sm" style="display:flex;align-items:center;gap:16px;flex-wrap:wrap;margin-bottom:14px">
      <a class="btn btn-cta" href="/free-report" style="font:700 16px/1 var(--font-body);padding:18px 32px;letter-spacing:.02em">Get Your Free Water Report <Icon name="arrow" size={18} /></a>
      <a class="btn btn-ghost" href="#flagship" style="font:700 16px/1 var(--font-body);padding:18px 28px">See the Complete System</a>
    </div>
    <div style="font:600 15px/1 var(--font-body);color:#d7e7f3">or call <a href={business.phoneHref} style="color:#fff;text-decoration:none">{business.phoneDisplay}</a></div>

    <!-- Rating badge (hidden until ENABLE_REVIEWS is true and reviewCount is real) -->
    {ENABLE_REVIEWS && (
      <div style="display:inline-flex;align-items:center;gap:12px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.14);padding:11px 18px;border-radius:12px;margin-top:26px">
        <span style="display:flex;gap:2px;color:#f0b429">
          <Icon name="star" size={16} /><Icon name="star" size={16} /><Icon name="star" size={16} /><Icon name="star" size={16} /><Icon name="star" size={16} />
        </span>
        <span style="font:600 13.5px/1.3 var(--font-body);color:#faf9f6">5-star rated &middot; <span style="color:#a9c2d6">{business.reviewCount} reviews</span></span>
      </div>
    )}
  </div>
</section>
