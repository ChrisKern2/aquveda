---
import { articles } from "../data/site";
import Icon from "./Icon.astro";
const posts = articles.slice(0, 4);
---
<section style="background:#f7f4ec">
  <div class="wrap" style="padding-top:74px;padding-bottom:74px">
    <div class="stack-sm" style="display:flex;align-items:flex-end;justify-content:space-between;gap:20px;margin-bottom:40px;flex-wrap:wrap">
      <div style="max-width:560px">
        <div style="font:600 12.5px/1 var(--font-body);letter-spacing:.14em;text-transform:uppercase;color:#1a5e91;margin-bottom:12px">Learn</div>
        <h2 style="font:700 40px/1.05 var(--font-display);letter-spacing:.01em;color:#143c5f;text-wrap:balance">Notes on Your Water</h2>
        <p style="font:400 17px/1.6 var(--font-body);color:#51606c;margin-top:10px">Plain-English answers about hard water, filtration, and what is actually in your tap.</p>
      </div>
      <a href="/learn" class="btn btn-navy" style="font:700 14px/1 var(--font-body);padding:14px 22px">All articles <Icon name="arrow" size={16} /></a>
    </div>

    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:20px">
      {posts.map((p) => (
        <a href={`/learn/${p.slug}`} class="card card-hover" style="padding:24px;display:flex;flex-direction:column;gap:11px;text-decoration:none">
          <span style="align-self:flex-start;font:600 11px/1 var(--font-body);letter-spacing:.06em;text-transform:uppercase;color:#1a5e91;background:#d7e7f3;padding:6px 10px;border-radius:100px">{p.tag}</span>
          <h3 style="font:700 17px/1.25 var(--font-body);color:#143c5f">{p.title}</h3>
          <p style="font:400 13.5px/1.6 var(--font-body);color:#51606c;flex:1">{p.excerpt}</p>
          <span style="font:700 13.5px/1 var(--font-body);color:#1a5e91;display:flex;align-items:center;gap:6px">Read <Icon name="arrow" size={14} /></span>
        </a>
      ))}
    </div>
  </div>
  <style>
    @media (max-width:880px){ section[style*="#f7f4ec"] div[style*="repeat(4"]{grid-template-columns:1fr 1fr !important} }
    @media (max-width:560px){ section[style*="#f7f4ec"] div[style*="repeat(4"]{grid-template-columns:1fr !important} }
  </style>
</section>
