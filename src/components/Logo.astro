---
// Wellbrook "The Ridgeline" logo: a navy roofline with blue water flowing
// beneath, plus the "Wellbrook / Water" wordmark in Bricolage Grotesque Bold.
//
// `variant` picks the correct asset for the background it sits on:
//   dark  -> navy lockup, for light backgrounds (Paper, Frost, Limestone, white)
//   light -> white lockup, for Well Navy / Ink / photo backgrounds
//
// Brand rules: never recolor, stretch, rotate, or add effects. The intrinsic
// aspect ratio (1382x424) is preserved by deriving width from height.
interface Props { variant?: "dark" | "light"; size?: number; href?: string; }
const { variant = "dark", size = 26, href = "/" } = Astro.props;

const reversed = variant === "light";
const src = reversed
  ? "/brand/wellbrook-logo-horizontal-white.png"
  : "/brand/wellbrook-logo-horizontal.png";

// `size` historically meant the wordmark cap height; the lockup reads right at
// roughly 1.55x that. Width follows the asset's native 1382:424 ratio.
const h = Math.round(size * 1.55);
const w = Math.round(h * (1382 / 424));
---
<a href={href} aria-label="Wellbrook Water home" style="text-decoration:none;display:inline-flex;align-items:center">
  <img
    src={src}
    alt="Wellbrook Water"
    width={w}
    height={h}
    style={`height:${h}px;width:auto;display:block`}
  />
</a>
