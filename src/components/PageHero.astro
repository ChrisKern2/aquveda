---
import { business } from "../data/site";
import Icon from "./Icon.astro";

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  image?: string;
  imageAlt?: string;
  crumbs?: { label: string; href?: string }[];
  showCta?: boolean;
}
const { eyebrow, title, subtitle, image, imageAlt = "", crumbs = [], showCta = true } = Astro.props;

// BreadcrumbList JSON-LD, built from the visible crumbs.
const site = business.domain;
const breadcrumbLd = crumbs.length > 1 ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: crumbs.map((c, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: c.label,
    ...(c.href ? { item: new URL(c.href, site).href } : {}),
  })),
} : null;
---
{breadcrumbLd && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />}
<section style="position:relative;overflow:hidden;background:radial-gradient(120% 130% at 80% 10%, #144a55 0%, #0e3a43 50%, #0a2128 100%)">
  {image && (
    <img src={image} alt={imageAlt} width="1600" height="700" loading="eager"
      style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:.20" />
  )}
  <div style="position:absolute;top:0;left:0;width:100%;height:4px;background:linear-gradient(90deg,#15919b 0%,#15919b 60%,transparent 100%)"></div>
  <div class="wrap" style="position:relative;padding-top:64px;padding-bottom:68px;max-width:860px">
    {crumbs.length > 0 && (
      <nav aria-label="Breadcrumb" style="display:flex;flex-wrap:wrap;gap:7px;margin-bottom:16px;font:600 12.5px/1 var(--font-body);color:#8fa0b8">
        {crumbs.map((c, i) => (
          <span style="display:flex;gap:7px;align-items:center">
            {c.href ? <a href={c.href} class="nav-link" style="color:#cde6e8;text-decoration:none">{c.label}</a> : <span style="color:#fff">{c.label}</span>}
            {i < crumbs.length - 1 && <span>/</span>}
          </span>
        ))}
      </nav>
    )}
    {eyebrow && <div style="font:600 12.5px/1 var(--font-body);letter-spacing:.14em;text-transform:uppercase;color:#7fd3dc;margin-bottom:14px">{eyebrow}</div>}
    <h1 style="font:700 46px/1.02 var(--font-display);letter-spacing:.01em;color:#fff;text-wrap:balance;margin-bottom:16px">{title}</h1>
    {subtitle && <p style="font:400 18px/1.65 var(--font-body);color:#cde6e8;max-width:560px;margin-bottom:26px">{subtitle}</p>}
    {showCta && (
      <div class="stack-sm" style="display:flex;align-items:center;gap:14px;flex-wrap:wrap">
        <a class="btn btn-primary" href="/free-report" style="font:700 15px/1 var(--font-body);padding:16px 28px">Get Your Free Water Report <Icon name="arrow" size={17} /></a>
        <a class="btn btn-ghost" href={business.phoneHref} style="font:700 15px/1 var(--font-body);padding:16px 24px">
          <span style="color:#7fd3dc;display:flex"><Icon name="phone" size={16} /></span>{business.phoneDisplay}
        </a>
      </div>
    )}
  </div>
</section>
