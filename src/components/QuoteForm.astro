---
// Native quote-request form. Replaces the retired Jobber clienthub embed,
// which no longer serves the form and rendered Jobber's own error banner.
// Posts to the same /api/free-report handler the water-report form uses,
// tagged formType:"quote_request" so the two lead types stay distinguishable.
---
<div class="card" style="padding:30px;box-shadow:0 20px 50px rgba(20,30,50,.12);border:none;border-radius:16px;background:#fff">
  <h2 style="margin:0 0 6px;color:#0E3A43;font-size:24px;font-weight:800">Request your free quote</h2>
  <p style="margin:0 0 22px;color:#5d6b71;font-size:15px;line-height:22px">
    Tell us what you need and we'll call you with a clear, no-obligation quote.
  </p>

  <form id="wq-quote-form">
    <!-- honeypot: hidden from humans -->
    <input type="text" name="website" tabindex="-1" autocomplete="off"
      style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0" aria-hidden="true" />

    <div style="display:grid;gap:14px">
      <input name="fullName" required placeholder="Full name *" autocomplete="name" class="wq-in" />
      <input name="email" type="email" required placeholder="Email *" autocomplete="email" class="wq-in" />
      <input name="phone" type="tel" required placeholder="Phone *" autocomplete="tel" class="wq-in" />
      <input name="address" required placeholder="Street address or ZIP *" autocomplete="street-address" class="wq-in" />

      <select name="system" id="wq-system" required class="wq-in" aria-label="System of interest">
        <option value="">System of interest *</option>
        <option>Reverse Osmosis</option>
        <option>Whole-Home Filtration &amp; Softening</option>
        <option>Complete Home Water System</option>
      </select>

      <textarea name="message" rows="3" placeholder="Anything we should know? (optional)" class="wq-in" style="resize:vertical"></textarea>

      <div id="wq-error" style="display:none;padding:12px 14px;background:#fdf3f2;border-radius:10px;color:#7a3b33;font-size:14px;line-height:1.5"></div>

      <button type="submit" id="wq-submit"
        style="background:#15919B;color:#fff;border:none;font-weight:800;font-size:16px;padding:15px;border-radius:30px;cursor:pointer">
        Request my free quote
      </button>
    </div>

    <p style="margin:14px 0 0;color:#8a9aa0;font-size:12px;line-height:17px">
      We use your details to prepare your quote and follow up about water treatment. We never sell your information.
    </p>
  </form>

  <div id="wq-result" style="display:none"></div>
</div>

<style>
  .wq-in{width:100%;box-sizing:border-box;padding:14px 16px;border:1px solid #d6dfe2;border-radius:10px;font-size:15px;color:#1e2d34;background:#fff;font-family:inherit}
  .wq-in:focus{outline:none;border-color:#15919B;box-shadow:0 0 0 3px rgba(21,145,155,.15)}
</style>

<script>
  const qForm = document.getElementById("wq-quote-form");
  const qResult = document.getElementById("wq-result");
  const qBtn = document.getElementById("wq-submit");
  const qError = document.getElementById("wq-error");

  // Pre-select the system from ?system= (set by the "Get Started" tier buttons).
  const qSystem = new URLSearchParams(location.search).get("system");
  if (qSystem) {
    const sel = document.getElementById("wq-system");
    for (const opt of sel.options) {
      if (opt.text.replace(/\s+/g, " ") === qSystem.replace(/\s+/g, " ")) { sel.value = opt.value || opt.text; break; }
    }
  }

  const Q_ZAPIER = "https://hooks.zapier.com/hooks/catch/28133353/4uop5l5/";

  // Same delivery contract as the free-report form: cors so we can read
  // response.ok, retry with backoff, never blocks the success UI.
  async function qSendLead(body) {
    for (let i = 0; i < 3; i++) {
      try {
        const r = await fetch(Q_ZAPIER, {
          method: "POST",
          mode: "cors",
          headers: { "Content-Type": "application/x-www-form-urlencoded" },
          body,
        });
        if (r.ok) return true;
      } catch (e) {}
      await new Promise((res) => setTimeout(res, 1500 * (i + 1)));
    }
    console.error("Zapier webhook failed after 3 attempts; lead still captured via the team email.");
    return false;
  }

  // Meta Lead event: browser Pixel + server Conversions API sharing one
  // eventID so Meta de-duplicates them into a single Lead conversion.
  function qMakeEventId() { return `lead_${Date.now()}_${Math.random().toString(36).slice(2)}`; }
  function qFireMetaLead(lead) {
    const eventId = qMakeEventId();
    if (window.fbq) window.fbq("track", "Lead", {}, { eventID: eventId });
    fetch("/api/meta-capi", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ eventId, email: lead.email, phone: lead.phone, zip: lead.zip, eventSourceUrl: location.href }),
    }).catch(() => {});
  }

  function qShowSuccess() {
    qForm.style.display = "none";
    qResult.style.display = "block";
    qResult.innerHTML = `<h2 style="color:#0E3A43;font-size:22px;margin:0 0 10px">We got it</h2>
      <p style="color:#5d6b71;font-size:15px;line-height:23px;margin:0">
      Thanks! We'll give you a call shortly at the number you provided to go over the details and
      put together your free, no-obligation quote. Want to talk sooner? Call
      <a href="tel:2678409239" style="color:#15919B;font-weight:700;text-decoration:none">(267) 840-9239</a>.</p>`;
  }

  function qShowError() {
    qError.style.display = "block";
    qError.innerHTML = `Sorry, that didn't go through. Call us at
      <a href="tel:2678409239" style="color:#15919B;font-weight:700;text-decoration:none">(267) 840-9239</a>
      or email <a href="mailto:chris@wellbrookwater.com" style="color:#15919B;font-weight:700;text-decoration:none">chris@wellbrookwater.com</a>
      and we'll get you your quote.`;
    qBtn.disabled = false;
    qBtn.textContent = "Request my free quote";
  }

  qForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    qError.style.display = "none";
    qBtn.disabled = true;
    qBtn.textContent = "Sending...";

    const fd = new FormData(qForm);
    const fullName = (fd.get("fullName") || "").toString().trim();
    const sp = fullName.indexOf(" ");
    const firstName = sp === -1 ? fullName : fullName.slice(0, sp);
    const lastName = sp === -1 ? "" : fullName.slice(sp + 1).trim();
    const address = (fd.get("address") || "").toString().trim();
    const zipMatch = address.match(/\b(\d{5})\b/);

    const apiBody = {
      formType: "quote_request",
      firstName,
      lastName,
      email: (fd.get("email") || "").toString().trim(),
      phone: (fd.get("phone") || "").toString().trim(),
      address,
      zip: zipMatch ? zipMatch[1] : "",
      system: (fd.get("system") || "").toString(),
      message: (fd.get("message") || "").toString().trim(),
      website: (fd.get("website") || "").toString(),
    };

    try {
      const res = await fetch("/api/free-report", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(apiBody),
      });
      const json = await res.json();
      if (!res.ok) { qShowError(); return; }

      if (json.status !== "ignored") {
        // Same downstream pipeline as the water report, tagged as a quote.
        qSendLead(new URLSearchParams({
          formType: "quote_request",
          first_name: firstName,
          last_name: lastName,
          email: apiBody.email,
          phone: apiBody.phone,
          zip: apiBody.zip,
          address,
          system: apiBody.system,
          message: apiBody.message,
          water_source: "",
          own_home: "",
          concern: "",
        }).toString());
        qFireMetaLead({ email: apiBody.email, phone: apiBody.phone, zip: apiBody.zip });
      }
      qShowSuccess();
    } catch (err) {
      qShowError();
    }
  });
</script>
