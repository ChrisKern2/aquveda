---
import Icon from "./Icon.astro";
const platforms = ["Google", "Facebook", "Yelp", "Nextdoor", "Angi", "BBB"];
---
<section style="background:#fff;border-bottom:1px solid rgba(14,58,67,.08)">
  <div class="wrap" style="padding-top:30px;padding-bottom:30px;display:flex;flex-direction:column;gap:16px;align-items:center;text-align:center">
    <div style="display:flex;align-items:center;gap:10px">
      <span style="display:flex;gap:2px;color:#f0b429">
        <Icon name="star" size={18} /><Icon name="star" size={18} /><Icon name="star" size={18} /><Icon name="star" size={18} /><Icon name="star" size={18} />
      </span>
      <span style="font:700 16px/1 var(--font-display);color:#0e3a43;letter-spacing:.01em">5-Star Rated Across Montgomery &amp; Chester County</span>
    </div>
    <div style="display:flex;align-items:center;justify-content:center;gap:14px 26px;flex-wrap:wrap">
      {platforms.map((p) => (
        <span style="display:flex;align-items:center;gap:7px;font:600 14px/1 var(--font-body);color:#5e7177">
          {p === "Google" && <span style="color:#4285F4;display:flex"><Icon name="google" size={17} /></span>}
          {p === "Facebook" && <span style="color:#1877F2;display:flex"><Icon name="facebook" size={17} /></span>}
          {p !== "Google" && p !== "Facebook" && <span style="color:#15919b;display:flex"><Icon name="drop" size={15} /></span>}
          {p}
        </span>
      ))}
    </div>
  </div>
</section>
