---
import { featuredTownNames } from "../data/site";
const list = featuredTownNames.join(", ");
---
<section style="background:#e9e1d2">
  <div class="wrap" style="padding-top:30px;padding-bottom:30px;text-align:center;display:flex;flex-direction:column;gap:8px;align-items:center">
    <h2 style="font:700 23px/1.25 var(--font-display);letter-spacing:.02em;color:#0e3a43;text-wrap:balance">
      Serving {list}, <span style="color:#15919b">and More</span>
    </h2>
    <p style="font:400 15px/1.6 var(--font-body);color:#5e7177;max-width:680px">
      Aquveda is locally owned and serves homes and businesses across the greater Philadelphia region, with a focus on the western suburbs in Montgomery and Chester County. Not sure if you're in our area? Just ask, we'll let you know the same day.
    </p>
  </div>
</section>
