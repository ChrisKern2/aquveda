---
import { systemTiers } from "../data/site";
import Icon from "./Icon.astro";
---
<section id="systems" style="background:#f7f4ec">
  <div class="wrap" style="padding-top:74px;padding-bottom:74px">
    <div style="text-align:center;max-width:660px;margin:0 auto 46px">
      <div style="font:600 12.5px/1 var(--font-body);letter-spacing:.14em;text-transform:uppercase;color:#15919b;margin-bottom:12px">Choose Your System</div>
      <h2 style="font:700 40px/1.05 var(--font-display);letter-spacing:.01em;color:#0e3a43;margin-bottom:14px;text-wrap:balance">Good, better, best, sized to your home</h2>
      <p style="font:400 17px/1.6 var(--font-body);color:#5e7177">Start with drinking water, treat every tap, or bundle both. Every option is installed by a licensed plumber and backed by our guarantee.</p>
    </div>

    <div class="grid-3" style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;align-items:stretch">
      {systemTiers.map((t) => (
        <div class="card" style={`display:flex;flex-direction:column;padding:32px 26px 28px;position:relative;background:#fff;${t.popular ? "border:2px solid #15919b;box-shadow:0 22px 55px rgba(14,58,67,.16)" : "border:1px solid #e6eef0"}`}>
          {t.popular && (
            <span style="position:absolute;top:-13px;left:50%;transform:translateX(-50%);background:#15919b;color:#fff;font:700 11px/1 var(--font-body);letter-spacing:.08em;text-transform:uppercase;padding:7px 15px;border-radius:100px;white-space:nowrap">Most Popular</span>
          )}
          <div style="height:152px;display:flex;align-items:center;justify-content:center;margin:6px 0 18px">
            <img src={t.image} alt={t.name} width="320" height="320" loading="lazy" style="max-height:100%;max-width:100%;object-fit:contain" />
          </div>
          <h3 style="font:700 22px/1.15 var(--font-display);letter-spacing:.01em;color:#0e3a43;margin-bottom:8px">{t.name}</h3>
          <p style="font:400 14.5px/1.5 var(--font-body);color:#5e7177;margin-bottom:16px;min-height:44px">{t.tagline}</p>

          <div style="display:flex;align-items:baseline;gap:9px;flex-wrap:wrap;margin-bottom:2px">
            {t.anchor && <span style="font:500 17px/1 var(--font-body);color:#9aa9ad;text-decoration:line-through">{t.anchor}</span>}
            <span style="font:700 32px/1 var(--font-display);color:#0e3a43">{t.price}</span>
            <span style="font:600 13px/1 var(--font-body);color:#15919b">installed</span>
          </div>
          <p style="font:500 12.5px/1.5 var(--font-body);color:#5e7177;margin:6px 0 0;min-height:34px">{t.priceNote ?? ""}</p>

          <ul style="list-style:none;padding:0;margin:14px 0 0;display:flex;flex-direction:column;gap:10px">
            {t.features.map((f) => (
              <li style="display:flex;align-items:flex-start;gap:10px">
                <span style="color:#1f8a5b;margin-top:1px;flex:none"><Icon name="check" size={17} /></span>
                <span style="font:500 14px/1.45 var(--font-body);color:#0e3a43">{f}</span>
              </li>
            ))}
          </ul>

          <a href={`/free-report?system=${encodeURIComponent(t.name)}`} class={t.popular ? "btn btn-primary" : "btn btn-navy"} style="font:700 14px/1 var(--font-body);padding:15px 20px;justify-content:center;margin-top:auto">Get Started <Icon name="arrow" size={16} /></a>
        </div>
      ))}
    </div>
    <p style="text-align:center;font:500 13.5px/1.5 var(--font-body);color:#5e7177;margin-top:22px">Not sure which fits? <a href="/free-report" style="color:#15919b;font-weight:700;text-decoration:none">Start with a free water report</a> and we'll size it for you.</p>
  </div>
</section>
