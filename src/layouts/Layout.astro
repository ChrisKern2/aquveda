---
import "../styles/global.css";
import { business, services, towns } from "../data/site";

interface Props {
  title: string;
  description: string;
  /** Path only, e.g. "/services/whole-home-filtration". Canonical + OG URL are built from site. */
  path?: string;
  image?: string;
  /** Extra JSON-LD objects (Service, FAQPage, town LocalBusiness, etc.). */
  schema?: object[];
  /** Keep the page out of search results (post-conversion pages, utility pages). */
  noindex?: boolean;
}

// Default social/OG image is the brand stacked lockup (PNG — most social
// platforms won't render an SVG OG image).
const { title, description, path = "/", image = "/brand/wellbrook-og.png", schema = [], noindex = false } = Astro.props;

const site = business.domain;
const canonical = new URL(path, site).href;
const ogImage = new URL(image, site).href;

// ---- Toggle this to true once you have genuine reviews to show. ----
const ENABLE_AGGREGATE_RATING = false;

const areaServed = [
  ...towns.map((t) => ({ "@type": "City", name: t.name })),
  { "@type": "AdministrativeArea", name: "Montgomery County, PA" },
  { "@type": "AdministrativeArea", name: "Chester County, PA" },
  { "@type": "AdministrativeArea", name: "Greater Philadelphia, PA" },
];

const localBusiness: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "@id": `${site}/#business`,
  name: business.name,
  url: site,
  telephone: business.phoneDisplay,
  email: business.email,
  image: ogImage,
  logo: new URL("/wellbrook-mark.png", site).href,
  priceRange: business.priceRange,
  foundingDate: String(business.foundedYear),
  address: {
    "@type": "PostalAddress",
    addressRegion: "PA",
    addressCountry: "US",
    // {{ADDRESS}}, add streetAddress / addressLocality / postalCode when known.
  },
  areaServed,
  knowsAbout: services.map((s) => s.name),
  sameAs: [business.social.facebook, business.social.instagram, business.social.google].filter(
    (u) => u && !u.startsWith("{{"),
  ),
};

if (ENABLE_AGGREGATE_RATING) {
  localBusiness.aggregateRating = {
    "@type": "AggregateRating",
    ratingValue: "5.0",
    reviewCount: business.reviewCount, // fill {{REVIEW_COUNT}} before enabling
  };
}

const jsonLd = [localBusiness, ...schema];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#143C5F" />

    <!-- Meta (Facebook) domain verification -->
    <meta name="facebook-domain-verification" content="8zrjyichrrj6lnq35wtywblwto0x6s" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={business.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts — Wellbrook "The Ridgeline": Bricolage Grotesque (display) +
         Source Sans 3 (body), with Bitter as the approved slab alternate. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@400;500;600;700&family=Source+Sans+3:wght@400;600;700&family=Bitter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Structured data -->
    {jsonLd.map((obj) => (
      <script type="application/ld+json" set:html={JSON.stringify(obj)} />
    ))}

    <!-- Meta Pixel Code -->
    <script is:inline>
      !function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)}(window, document,'script',
      'https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', '1025841546937119');
      fbq('track', 'PageView');
    </script>
    <noscript><img height="1" width="1" style="display:none"
      src="https://www.facebook.com/tr?id=1025841546937119&ev=PageView&noscript=1"
    /></noscript>
    <!-- End Meta Pixel Code -->
  </head>
  <body>
    <slot />

    <!-- HighLevel chat widget (A2P 10DLC compliance) — is:inline so Astro
         doesn't bundle/defer it and strip the data-* attributes it reads.
         NOT rendered on pages with a phone-collecting form (/contact,
         /free-report): carriers reject registrations where the widget shares
         a page with another opt-in source ("Multiple Opt-ins" check). The
         homepage MUST carry the widget — HighLevel's checker crawls the root
         domain — which is why its quote form moved to /contact. If a phone
         form is ever added to another page, add its path here. -->
    {!["/contact", "/free-report"].includes(path) && (
      <script
        is:inline
        src="https://widgets.leadconnectorhq.com/loader.js"
        data-resources-url="https://widgets.leadconnectorhq.com/chat-widget/loader.js"
        data-widget-id="6a6224d602d958a92e70c237"
        data-source="WEB_USER"></script>
    )}
  </body>
</html>
