---
import Layout from "../layouts/Layout.astro";
import TopBar from "../components/TopBar.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import ReviewLogos from "../components/ReviewLogos.astro";
import CredentialBar from "../components/CredentialBar.astro";
import FlagshipSystem from "../components/FlagshipSystem.astro";
import ServiceGrid from "../components/ServiceGrid.astro";
import CTABand from "../components/CTABand.astro";
import HowItWorks from "../components/HowItWorks.astro";
import ComparisonTable from "../components/ComparisonTable.astro";
import StatBand from "../components/StatBand.astro";
import Testimonials from "../components/Testimonials.astro";
import LearnPreview from "../components/LearnPreview.astro";
import HomeFaq from "../components/HomeFaq.astro";
import ServiceAreaList from "../components/ServiceAreaList.astro";
import QuoteForm from "../components/QuoteForm.astro";
import Footer from "../components/Footer.astro";
import Icon from "../components/Icon.astro";
import { business, flagship, homeFaqs } from "../data/site";

const site = business.domain;
const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: flagship.name,
  description: flagship.tagline,
  brand: { "@type": "Brand", name: "Aquveda" },
  image: new URL(flagship.image, site).href,
  offers: {
    "@type": "Offer",
    price: "2699",
    priceCurrency: "USD",
    availability: "https://schema.org/InStock",
    priceValidUntil: "2026-07-31",
    url: site,
  },
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: homeFaqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---
<Layout
  title="Aquveda | Whole-Home Water Filtration & Softening in Greater Philadelphia"
  description="The Complete Home Water System: whole-home softening and filtration plus reverse-osmosis drinking water, $2,699 installed during founder pricing (regularly $5,998). Free, no-obligation quotes across Greater Philadelphia, focused on the western suburbs."
  path="/"
  schema={[productSchema, faqSchema]}
>
  <TopBar />
  <Header />
  <Hero />
  <ReviewLogos />
  <CredentialBar />
  <FlagshipSystem />
  <ServiceGrid />
  <HowItWorks />
  <ComparisonTable />
  <StatBand />
  <Testimonials />
  <LearnPreview />
  <HomeFaq />

  <!-- QUOTE / JOBBER FORM -->
  <section id="quote" style="background:#0e3a43">
    <div class="wrap hero-grid" style="padding-top:74px;padding-bottom:74px;display:grid;grid-template-columns:1fr 1fr;gap:50px;align-items:start">
      <div style="display:flex;flex-direction:column;gap:18px">
        <div style="font:600 12.5px/1 var(--font-body);letter-spacing:.14em;text-transform:uppercase;color:#7fd3dc">Free Quote</div>
        <h2 style="font:700 40px/1.05 var(--font-display);letter-spacing:.01em;color:#fff;text-wrap:balance">Get your free quote</h2>
        <p style="font:400 17px/1.65 var(--font-body);color:#cde6e8;max-width:440px">Tell us about your home and we'll send a clear, no-obligation quote for the right system, often the same day. Prefer to talk? Call us at <a href="tel:2159789719" style="color:#7fd3dc;font-weight:600;text-decoration:none">(215) 978-9719</a>.</p>
        <div style="display:flex;flex-direction:column;gap:13px;margin-top:6px">
          {["Free, no-obligation quote", "Upfront, honest pricing", "Licensed & fully insured", "Lifetime workmanship warranty"].map((t) => (
            <div style="display:flex;align-items:center;gap:11px;color:#5fcf97"><Icon name="check" size={19} /><span style="font:500 15px/1 var(--font-body);color:#e3e8ef">{t}</span></div>
          ))}
        </div>
      </div>
      <QuoteForm />
    </div>
  </section>

  <ServiceAreaList />
  <CTABand tone="red" title="Get your free quote today" subtitle="Tell us what you need and we'll send a clear, no-obligation quote. Call us now or send a message, we respond the same day." />
  <Footer />
</Layout>
