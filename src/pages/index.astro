---
import Layout from "../layouts/Layout.astro";
import TopBar from "../components/TopBar.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import ServiceAreaBand from "../components/ServiceAreaBand.astro";
import ServiceGrid from "../components/ServiceGrid.astro";
import CTABand from "../components/CTABand.astro";
import WhyChooseGrid from "../components/WhyChooseGrid.astro";
import StatBand from "../components/StatBand.astro";
import Testimonials from "../components/Testimonials.astro";
import ServiceAreaList from "../components/ServiceAreaList.astro";
import QuoteForm from "../components/QuoteForm.astro";
import Footer from "../components/Footer.astro";
import Icon from "../components/Icon.astro";
---
<Layout
  title="Aquveda | Whole-Home Water Filtration & Softening in Montgomery & Chester County"
  description="Professional whole-home filtration, softening & drinking water across Blue Bell, Malvern, Exton, West Chester & nearby. Licensed, insured, free in-home water tests."
  path="/"
>
  <TopBar />
  <Header />
  <Hero />
  <ServiceAreaBand />
  <ServiceGrid />
  <CTABand tone="parchment" title="Get the Help You Need" subtitle="From a one-time refresh to a recurring plan, we make it easy. Call us or request a free quote today." />
  <WhyChooseGrid />
  <StatBand />
  <Testimonials />

  <!-- QUOTE / JOBBER FORM -->
  <section id="quote" style="background:#0e3a43">
    <div class="wrap hero-grid" style="padding-top:74px;padding-bottom:74px;display:grid;grid-template-columns:1fr 1fr;gap:50px;align-items:start">
      <div style="display:flex;flex-direction:column;gap:18px">
        <div style="font:600 12.5px/1 var(--font-body);letter-spacing:.14em;text-transform:uppercase;color:#7fd3dc">Free Quote</div>
        <h2 style="font:700 40px/1.05 var(--font-display);letter-spacing:.01em;color:#fff;text-wrap:balance">Request Your Free, Same-Day Quote</h2>
        <p style="font:400 17px/1.65 var(--font-body);color:#cde6e8;max-width:440px">Tell us what you need and we'll get back to you the same day with a clear, no-obligation price. Prefer to talk? Call us at <a href="tel:2159789719" style="color:#7fd3dc;font-weight:600;text-decoration:none">(215) 978-9719</a>.</p>
        <div style="display:flex;flex-direction:column;gap:13px;margin-top:6px">
          {["Same-day response", "No-obligation, upfront pricing", "Licensed & fully insured", "workmanship warranty"].map((t) => (
            <div style="display:flex;align-items:center;gap:11px;color:#5fcf97"><Icon name="check" size={19} /><span style="font:500 15px/1 var(--font-body);color:#e3e8ef">{t}</span></div>
          ))}
        </div>
      </div>
      <QuoteForm />
    </div>
  </section>

  <ServiceAreaList />
  <CTABand tone="red" title="Get the Help You Need, Today" subtitle="Call us now or send a message. We'll get you a free, no-obligation quote the same day." />
  <Footer />
</Layout>
