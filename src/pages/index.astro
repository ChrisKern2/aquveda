---
import Layout from "../layouts/Layout.astro";
import TopBar from "../components/TopBar.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import ReviewLogos from "../components/ReviewLogos.astro";
import CredentialBar from "../components/CredentialBar.astro";
import FlagshipSystem from "../components/FlagshipSystem.astro";
import SystemTiers from "../components/SystemTiers.astro";
import GuaranteeBar from "../components/GuaranteeBar.astro";
import CarePlan from "../components/CarePlan.astro";
import ServiceGrid from "../components/ServiceGrid.astro";
import CTABand from "../components/CTABand.astro";
import HowItWorks from "../components/HowItWorks.astro";
import ComparisonTable from "../components/ComparisonTable.astro";
import StatBand from "../components/StatBand.astro";
import Testimonials from "../components/Testimonials.astro";
import LearnPreview from "../components/LearnPreview.astro";
import HomeFaq from "../components/HomeFaq.astro";
import ServiceAreaList from "../components/ServiceAreaList.astro";
import QuoteForm from "../components/QuoteForm.astro";
import Footer from "../components/Footer.astro";
import Icon from "../components/Icon.astro";
import { business, flagship, homeFaqs, ENABLE_REVIEWS } from "../data/site";

const site = business.domain;
const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: flagship.name,
  description: flagship.tagline,
  brand: { "@type": "Brand", name: "Wellbrook" },
  image: new URL(flagship.image, site).href,
  offers: {
    "@type": "Offer",
    price: "2899",
    priceCurrency: "USD",
    availability: "https://schema.org/InStock",
    priceValidUntil: "2026-12-31",
    url: site,
  },
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: homeFaqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---
<Layout
  title="Wellbrook | Whole-Home Water Filtration & Softening in Greater Philadelphia"
  description="The Complete Home Water System: whole-home softening and filtration plus reverse-osmosis drinking water, $2,899 installed during founder pricing (regularly $5,998). Free, no-obligation quotes across Greater Philadelphia, focused on the western suburbs."
  path="/"
  schema={[productSchema, faqSchema]}
>
  <TopBar />
  <Header />
  <Hero />
  {ENABLE_REVIEWS && <ReviewLogos />}
  <CredentialBar />
  <FlagshipSystem />
  <SystemTiers />
  <GuaranteeBar />
  <ServiceGrid />
  <HowItWorks />
  <CarePlan />
  <ComparisonTable />
  <StatBand />
  {ENABLE_REVIEWS && <Testimonials />}
  <LearnPreview />
  <HomeFaq />

  <!-- QUOTE / JOBBER FORM -->
  <section id="quote" style="background:#143c5f">
    <div class="wrap hero-grid" style="padding-top:74px;padding-bottom:74px;display:grid;grid-template-columns:1fr 1fr;gap:50px;align-items:start">
      <div style="display:flex;flex-direction:column;gap:18px">
        <div style="font:600 12.5px/1 var(--font-body);letter-spacing:.14em;text-transform:uppercase;color:#7dbee6">Ready Now?</div>
        <h2 style="font:700 40px/1.05 var(--font-display);letter-spacing:.01em;color:#fff;text-wrap:balance">Skip ahead and request a quote</h2>
        <p style="font:400 17px/1.65 var(--font-body);color:#d7e7f3;max-width:440px">Already know what you need? Tell us about your home and we'll send a clear, no-obligation quote, often the same day. Not sure yet? <a href="/free-report" style="color:#7dbee6;font-weight:600;text-decoration:none">Start with a free water report</a> or call <a href="tel:2674123549" style="color:#7dbee6;font-weight:600;text-decoration:none">(267) 412-3549</a>.</p>
        <div style="display:flex;flex-direction:column;gap:13px;margin-top:6px">
          {["Free, no-obligation quote", "Upfront, honest pricing", "Licensed & fully insured", "Lifetime workmanship warranty"].map((t) => (
            <div style="display:flex;align-items:center;gap:11px;color:#5fcf97"><Icon name="check" size={19} /><span style="font:500 15px/1 var(--font-body);color:#faf9f6">{t}</span></div>
          ))}
        </div>
      </div>
      <QuoteForm />
    </div>
  </section>

  <ServiceAreaList />
  <CTABand tone="navy" />
  <Footer />
</Layout>
