---
import Layout from "../layouts/Layout.astro";
import TopBar from "../components/TopBar.astro";
import Header from "../components/Header.astro";
import PageHero from "../components/PageHero.astro";
import Footer from "../components/Footer.astro";
import { business } from "../data/site";
---
<Layout title="Terms of Service | Wellbrook" description="The terms that apply when you use the Wellbrook website and services." path="/terms">
  <TopBar />
  <Header />
  <PageHero eyebrow="Legal" title="Terms of Service" crumbs={[{ label: "Home", href: "/" }, { label: "Terms" }]} />
  <section style="background:#fff">
    <div class="wrap prose" style="padding-top:56px;padding-bottom:70px;max-width:760px">
      <p><strong>Last updated:</strong> July 21, 2026</p>
      <p>These terms apply when you use the Wellbrook Water website or request our services. By using this site you agree to them.</p>
      <p><strong>Quotes &amp; estimates.</strong> Quotes provided through this site or by phone are estimates based on the information you provide and may be adjusted after an on-site assessment.</p>
      <p><strong>Satisfaction guarantee.</strong> We stand behind our work with a lifetime workmanship warranty. If you're not satisfied, contact us promptly and we'll make it right.</p>
      <p><strong>Contact.</strong> Questions? Email <a href={`mailto:${business.email}`} style="color:#1a5e91;font-weight:600;text-decoration:none">{business.email}</a> or call {business.phoneDisplay}.</p>
    </div>
  </section>
  <Footer />
</Layout>
